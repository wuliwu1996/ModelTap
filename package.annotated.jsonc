{
  // 项目名称。npm 包名，建议小写和短横线风格。
  "name": "llm-wenda-page",

  // 项目版本号（语义化版本）。
  "version": "0.1.0",

  // true 表示私有项目，不允许 publish 到 npm 公共仓库。
  "private": true,

  // Electron 主进程入口文件。
  "main": "electron/main.js",

  // npm 脚本命令集合。
  "scripts": {
    // 前端开发模式（Vue CLI dev server）。
    "serve": "vue-cli-service serve",
    // 构建前端产物到 dist。
    "build": "vue-cli-service build",
    // 代码风格检查。
    "lint": "vue-cli-service lint",
    // 先构建前端，再直接启动 Electron（本地运行，不出安装包）。
    "electron:start": "npm run build && electron .",
    // 先构建前端，再用 electron-builder 打 Windows NSIS 安装包。
    "build:electron": "npm run build && electron-builder --win nsis",
    // 先构建前端，再打“解包目录”（不生成安装器）。
    "pack:electron": "npm run build && electron-builder --dir"
  },

  // 运行时依赖（打包后应用运行需要）。
  "dependencies": {
    "core-js": "^3.49.0",
    "dompurify": "^3.4.1",
    "markdown-it": "^14.1.1",
    "regenerator-runtime": "^0.14.1",
    "vue": "^2.6.14",
    "whatwg-fetch": "^3.6.20"
  },

  // 开发依赖（构建、打包、编译、lint 等开发阶段需要）。
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "electron": "^34.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "vue-template-compiler": "^2.6.14"
  },

  // electron-builder 配置。
  "build": {
    // 应用唯一 ID（Windows 注册表、安装器元数据等会使用）。
    "appId": "com.llm.wenda.page",

    // 产品名（安装后显示名、开始菜单名、卸载列表名等）。
    "productName": "大模型问答器",

    // 指定 Electron 二进制目录（本地 node_modules）。
    "electronDist": "node_modules/electron/dist",

    // 打包输出目录。
    "directories": {
      "output": "release"
    },

    // 打包时包含到应用中的文件。
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    // Windows 平台构建配置。
    "win": {
      // 关闭可执行文件签名与资源编辑（通常用于本地未签名构建）。
      "signAndEditExecutable": false,
      // Windows 图标路径（建议 256x256 多尺寸 ICO）。
      "icon": "build/icon.ico",
      // 构建目标列表：NSIS 安装器，架构 x64。
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },

    // NSIS 安装器配置。
    "nsis": {
      // false=向导式安装；true=一键安装。
      "oneClick": false,
      // 允许用户在安装界面修改安装目录。
      "allowToChangeInstallationDirectory": true,
      // 允许在需要时申请管理员权限（UAC）。
      "allowElevation": true,
      // 默认是否按“所有用户安装”（true=所有用户，false=当前用户）。
      "perMachine": false,
      // 安装界面默认是否选中“所有用户安装”。
      "selectPerMachineByDefault": false
    }
  },

  // ESLint 配置。
  "eslintConfig": {
    // 作为 ESLint 配置根，避免向上级目录继续合并配置。
    "root": true,
    // 运行环境变量预设。
    "env": {
      "node": true
    },
    // 继承的规则集。
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    // 解析器相关配置。
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    // 项目自定义规则（当前为空）。
    "rules": {}
  },

  // 浏览器兼容目标（影响 Babel/polyfill 等构建行为）。
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "ie 11"
  ]
}
